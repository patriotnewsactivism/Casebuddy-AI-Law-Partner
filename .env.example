# ─── CaseBuddy Environment Variables ───────────────────────────────
# Copy this file to .env.local and fill in your values.
# Do NOT commit .env.local to version control.

# ── Gemini AI (required for all AI features) ──
# Get a free key at https://aistudio.google.com/
GEMINI_API_KEY=
VITE_GEMINI_API_KEY=

# ── Firm Identity (required for intake matching) ──
# Your firm UUID — scopes your public intake form submissions to your account.
# This is AUTO-GENERATED and stored in firm_memberships when you first sign in.
# To find your firm_id after signing in:
#   Supabase Dashboard → Table Editor → firm_memberships → copy your firm_id
# IMPORTANT: Each account must use its own unique firm_id.
# Do NOT share or copy firm_ids between accounts — this would break
# attorney-client privilege isolation.
VITE_FIRM_ID=

# ── Supabase (required for auth & cloud sync) ──
# Create a project at https://supabase.com/
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Supabase Service Key (server-side only — Vercel env vars) ──
# SUPABASE_SERVICE_ROLE_KEY=

# ── Deepgram (optional — real-time voice transcription) ──
# VITE_DEEPGRAM_API_KEY=

# ── Email & SMS (optional) ──
# SENDGRID_API_KEY=
# FIRM_OWNER_EMAIL=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
# FIRM_OWNER_PHONE=

# ── Cron Security (optional — protects cron endpoints) ──
# CRON_SECRET=

# ── Groq (optional — fast transcription & evidence analysis) ──
# VITE_GROQ_API_KEY=

# ── CourtListener (optional — case law search) ──
# VITE_COURTLISTENER_API_KEY=

# ── CORS (optional — restrict AI proxy to your domain) ──
# ALLOWED_ORIGIN=https://casebuddy.live

# ── DeepSeek (deprecated — credits exhausted, all calls routed through Gemini) ──
# DEEPSEEK_API_KEY=
# VITE_DEEPSEEK_API_KEY=
