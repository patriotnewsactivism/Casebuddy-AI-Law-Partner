# ─── CaseBuddy Environment Variables ───────────────────────────────
# Copy this file to .env.local and fill in your values.
# Do NOT commit .env.local to version control.

# ── Gemini AI (required for all AI features) ──
# Get a free key at https://aistudio.google.com/
GEMINI_API_KEY=
VITE_GEMINI_API_KEY=

# ── Firm Identity (required for intake matching) ──
# Your firm UUID — ensures public intakes appear on your dashboard.
# Get it from: browser DevTools console → localStorage.getItem('casebuddy_firm_id')
# If not set, intakes will use 'default' as the firm_id.
VITE_FIRM_ID=

# ── Supabase (required for auth & cloud sync) ──
# Create a project at https://supabase.com/
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Supabase Service Key (server-side only — Vercel env vars) ──
# SUPABASE_SERVICE_ROLE_KEY=

# ── Deepgram (optional — real-time voice transcription) ──
# VITE_DEEPGRAM_API_KEY=

# ── Email & SMS (optional) ──
# SENDGRID_API_KEY=
# FIRM_OWNER_EMAIL=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
# FIRM_OWNER_PHONE=

# ── Cron Security (optional — protects cron endpoints) ──
# CRON_SECRET=

# ── CourtListener (optional — case law search) ──
# VITE_COURTLISTENER_API_KEY=

# ── DeepSeek (deprecated — credits exhausted, all calls routed through Gemini) ──
# DEEPSEEK_API_KEY=
# VITE_DEEPSEEK_API_KEY=
